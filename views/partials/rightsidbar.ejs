<!-- Main Sidebar -->
<div class="main-sidebar">
    <!-- Logo Section -->
    <div class="logo-container">
        <a href="/" class="logo">
        </a>
        <div class=" logo-text">بيلا سيتي
        </div>
        <div class="logo-subtext">نظام الإدارة</div>
    </div>

    <!-- Main Navigation -->
    <div class="main-nav">
        <a href="/" class="main-nav-button <%= page === 'dashboard' ? 'active' : '' %>">
            <i class="fas fa-home"></i>
            <span>الرئيسية</span>
        </a>

        <!-- Vendors Submenu -->
        <div class="nav-item-group">
            <a href="javascript:void(0)" class="main-nav-button <%= page === 'vendors' ? 'active' : '' %>"
                onclick="toggleSubMenu('vendors-submenu', this)">
                <i class="fas fa-truck"></i>
                <span>الموردين</span>
                <i class="fas fa-chevron-down toggle-icon" <%- page==='vendors'
                    ? 'style="margin-right: auto; transition: transform 0.3s; transform: rotate(180deg);"'
                    : 'style="margin-right: auto; transition: transform 0.3s;"' %>></i>
            </a>

            <div id="vendors-submenu" class="submenu" <%- page==='vendors'
                ? 'style="display: block; background-color: rgba(0,0,0,0.02); border-radius: 8px; margin-top: 5px; margin-bottom: 5px; padding: 5px 15px 5px 0; border-right: 2px solid #3498db;"'
                : 'style="display: none; background-color: rgba(0,0,0,0.02); border-radius: 8px; margin-top: 5px; margin-bottom: 5px; padding: 5px 15px 5px 0; border-right: 2px solid #3498db;"'
                %>>
                <a href="/vendors/data" class="main-nav-button"
                    style="font-size: 0.9em; padding: 10px; margin-bottom: 2px; height: auto;">
                    <i class="fas fa-user-tie" style="font-size: 0.9em;"></i>
                    <span>بيانات الموردين</span>
                </a>
                <a href="#" class="main-nav-button"
                    style="font-size: 0.9em; padding: 10px; margin-bottom: 2px; height: auto;">
                    <i class="fas fa-file-invoice" style="font-size: 0.9em;"></i>
                    <span>فاتورة شراء</span>
                </a>
                <a href="#" class="main-nav-button"
                    style="font-size: 0.9em; padding: 10px; margin-bottom: 2px; height: auto;">
                    <i class="fas fa-undo-alt" style="font-size: 0.9em;"></i>
                    <span>مردودات</span>
                </a>
                <a href="#" class="main-nav-button"
                    style="font-size: 0.9em; padding: 10px; margin-bottom: 2px; height: auto;">
                    <i class="fas fa-file-contract" style="font-size: 0.9em;"></i>
                    <span>إشعار دائن</span>
                </a>
                <a href="#" class="main-nav-button"
                    style="font-size: 0.9em; padding: 10px; margin-bottom: 2px; height: auto;">
                    <i class="fas fa-file-invoice-dollar" style="font-size: 0.9em;"></i>
                    <span>إشعار مدين</span>
                </a>
                <a href="#" class="main-nav-button" style="font-size: 0.9em; padding: 10px; height: auto;">
                    <i class="fas fa-money-check-alt" style="font-size: 0.9em;"></i>
                    <span>سداد</span>
                </a>
            </div>
        </div>

        <!-- Customers Submenu -->
        <div class="nav-item-group">
            <a href="javascript:void(0)" class="main-nav-button <%= page === 'customers' ? 'active' : '' %>"
                onclick="toggleSubMenu('customers-submenu', this)">
                <i class="fas fa-users"></i>
                <span>العملاء</span>
                <i class="fas fa-chevron-down toggle-icon" <%- page==='customers'
                    ? 'style="margin-right: auto; transition: transform 0.3s; transform: rotate(180deg);"'
                    : 'style="margin-right: auto; transition: transform 0.3s;"' %>></i>
            </a>

            <div id="customers-submenu" class="submenu" <%- page==='customers'
                ? 'style="display: block; background-color: rgba(0,0,0,0.02); border-radius: 8px; margin-top: 5px; margin-bottom: 5px; padding: 5px 15px 5px 0; border-right: 2px solid #3498db;"'
                : 'style="display: none; background-color: rgba(0,0,0,0.02); border-radius: 8px; margin-top: 5px; margin-bottom: 5px; padding: 5px 15px 5px 0; border-right: 2px solid #3498db;"'
                %>>
                <a href="/customers/data" class="main-nav-button"
                    style="font-size: 0.9em; padding: 10px; margin-bottom: 2px; height: auto;">
                    <i class="fas fa-user-tie" style="font-size: 0.9em;"></i>
                    <span>بيانات العملاء</span>
                </a>
                <a href="/customers/sales_list" class="main-nav-button"
                    style="font-size: 0.9em; padding: 10px; margin-bottom: 2px; height: auto;">
                    <i class="fas fa-file-invoice" style="font-size: 0.9em;"></i>
                    <span>المبيعات</span>
                </a>
                <a href="/customers/bounce_list" class="main-nav-button"
                    style="font-size: 0.9em; padding: 10px; margin-bottom: 2px; height: auto;">
                    <i class="fas fa-file-invoice" style="font-size: 0.9em;"></i>
                    <span>الحوافز</span>
                </a>
                <a href="/customers/gifts_list" class="main-nav-button"
                    style="font-size: 0.9em; padding: 10px; margin-bottom: 2px; height: auto;">
                    <i class="fas fa-file-invoice" style="font-size: 0.9em;"></i>
                    <span>الهدايا</span>
                </a>
                <a href="#" class="main-nav-button"
                    style="font-size: 0.9em; padding: 10px; margin-bottom: 2px; height: auto;">
                    <i class="fas fa-undo-alt" style="font-size: 0.9em;"></i>
                    <span>مردودات</span>
                </a>
                <a href="#" class="main-nav-button"
                    style="font-size: 0.9em; padding: 10px; margin-bottom: 2px; height: auto;">
                    <i class="fas fa-file-contract" style="font-size: 0.9em;"></i>
                    <span>إشعار دائن</span>
                </a>
                <a href="#" class="main-nav-button"
                    style="font-size: 0.9em; padding: 10px; margin-bottom: 2px; height: auto;">
                    <i class="fas fa-file-invoice-dollar" style="font-size: 0.9em;"></i>
                    <span>إشعار مدين</span>
                </a>
                <a href="#" class="main-nav-button" style="font-size: 0.9em; padding: 10px; height: auto;">
                    <i class="fas fa-money-check-alt" style="font-size: 0.9em;"></i>
                    <span>تحصيل</span>
                </a>
            </div>
        </div>

        <a href="#" class="main-nav-button">
            <i class="fas fa-calculator"></i>
            <span>الحسابات</span>
        </a>

        <a href="#" class="main-nav-button">
            <i class="fas fa-boxes"></i>
            <span>المخزون</span>
        </a>

        <a href="#" class="main-nav-button">
            <i class="fas fa-headset"></i>
            <span>خدمة العملاء</span>
        </a>

        <!--  Reports -->
        <a href="/reports" class="main-nav-button <%= page === 'reports' ? 'active' : '' %>">
            <i class="fas fa-chart-line"></i>
            <span>التقارير</span>
        </a>
        <!-- Settings -->
        <a href="#" class="main-nav-button">
            <i class="fas fa-cog"></i>
            <span>الإعدادات</span>
        </a>
    </div>

    <!-- User Profile -->
    <div class="user-profile">
        <div class="user-info">
            <div class="user-avatar">
                <i class="fas fa-user"></i>
            </div>
            <div style="flex: 1;">
                <div style="font-size: 14px; font-weight: bold;">المستخدم</div>

                <div style="font-size: 16px; opacity: 0.8;">
                    <%= req.session.show_name %>
                </div>

            </div>
            <a href="/logout" title="تسجيل الخروج"
                style="color: #e74c3c; font-size: 18px; text-decoration: none; margin-right: 10px;">
                <i class="fas fa-sign-out-alt"></i>
            </a>
        </div>
    </div>
</div>

<script>
    function toggleSubMenu(id, element) {
        var submenu = document.getElementById(id);
        var icon = element.querySelector('.toggle-icon');
        if (submenu.style.display === "none" || submenu.style.display === "") {
            submenu.style.display = "block";
            if (icon) icon.style.transform = "rotate(180deg)";
        } else {
            submenu.style.display = "none";
            if (icon) icon.style.transform = "rotate(0deg)";
        }
    }
</script>