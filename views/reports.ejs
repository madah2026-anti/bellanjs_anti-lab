            document.addEventListener('DOMContentLoaded', function () {
                const periodSelect = document.getElementById('period-select');
                const fromDateInput = document.getElementById('from-date');
                const toDateInput = document.getElementById('to-date');
                const categorySelect = document.getElementById('category-select');
                const reportNamesList = document.getElementById('list-report-names');

                const categoryMap = {
                    'suppliers': [110, 120, 130, 140],
                    'inventory': [210, 220, 230, 240, 250, 252, 260, 261, 264, 265, 266, 267, 268, 270, 280, 282, 290],
                    'customers': [405, 415, 416, 417, 420, 421, 422, 423, 425, 427, 430, 435, 436, 440, 450, 460, 461, 462, 463, 465, 466, 467, 468, 469, 470, 480, 490, 495],
                    'sales': [510, 520, 530, 540, 550, 551, 552, 553, 554, 556, 560, 565, 570, 572, 575, 576, 577, 578, 580, 585, 590],
                    'accounts': [710, 712, 713, 714, 715, 716, 720, 730, 740],
                    'purchases': [910, 920, 922, 930, 935, 936, 940, 945, 946, 947, 948, 950, 953, 955, 956, 957, 960, 963, 965, 966, 967, 968, 970, 972, 974, 982, 984, 985, 986, 990, 991, 992, 993, 995, 996]
                };

                function updateReportList() {
                    const selectedCategory = categorySelect.value;
                    const reportIds = categoryMap[selectedCategory] || [];

                    reportNamesList.innerHTML = ''; // Clear current list

                    reportIds.forEach(id => {
                        const name = getRptName(id);
                        if (name) {
                            const div = document.createElement('div');
                            div.className = 'list-item';
                            div.textContent = name;
                            div.dataset.reportId = id; // Save the report ID for future reference
                            reportNamesList.appendChild(div);
                        }
                    });
                }

                // Listen for category changes
                categorySelect.addEventListener('change', updateReportList);

                // Initialize the list on page load
                updateReportList();

                const searchList = document.getElementById('search-list');
                const searchListCount = document.getElementById('search-list-count');
                const searchInput = document.querySelector('.search-input');
                let currentSearchData = [];

                function renderSearchList(data) {
                    searchList.innerHTML = '';
                    data.forEach(item => {
                        const div = document.createElement('div');
                        div.className = 'list-item';
                        div.textContent = item.cf_t1 || 'بدون اسم';
                        div.dataset.id = item.cf_id;
                        searchList.appendChild(div);
                    });
                    searchListCount.textContent = `العدد: ${data.length}`;
                    searchListCount.style.display = 'flex';
                    searchListCount.style.alignItems = 'center';
                    searchListCount.style.justifyContent = 'center';
                    searchListCount.style.fontWeight = 'bold';
                }

                reportNamesList.addEventListener('click', function (e) {
                    if (e.target.classList.contains('list-item')) {
                        // Highlight selection
                        document.querySelectorAll('#list-report-names .list-item').forEach(el => el.style.backgroundColor = '');
                        e.target.style.backgroundColor = '#e0f0ff';

                        const reportId = e.target.dataset.reportId;
                        const category = categorySelect.value;

                        // Fetch data
                        fetch(`/api/report-data?reportId=${reportId}&category=${category}`)
                            .then(response => response.json())
                            .then(data => {
                                currentSearchData = data;
                                renderSearchList(currentSearchData);
                            })
                            .catch(error => console.error('Error fetching data:', error));
                    }
                });

                if (searchInput) {
                    searchInput.addEventListener('input', function (e) {
                        const searchTerm = e.target.value.toLowerCase();
                        if (!currentSearchData) return;

                        const filteredData = currentSearchData.filter(item => {
                            const text = item.cf_t1 ? item.cf_t1.toLowerCase() : '';
                            return text.includes(searchTerm);
                        });

                        renderSearchList(filteredData);
                    });
                }

                function formatDate(date) {

                    const year = date.getFullYear();
                    const month = String(date.getMonth() + 1).padStart(2, '0');
                    const day = String(date.getDate()).padStart(2, '0');

                    return `${year}-${month}-${day}`;
                }

                periodSelect.addEventListener('change', function () {
                    const value = this.value;
                    const today = new Date();
                    let fromDate = new Date();
                    let toDate = new Date();

                    switch (value) {
                        case 'none':
                            fromDateInput.value = '';
                            toDateInput.value = '';
                            return;
                        case 'prev_day':
                            fromDate.setDate(today.getDate() - 1);
                            toDate.setDate(today.getDate() - 1);
                            break;
                        case 'curr_day':
                            fromDate = today;
                            toDate = today;
                            break;
                        case 'next_day':
                            fromDate.setDate(today.getDate() + 1);
                            toDate.setDate(today.getDate() + 1);
                            break;
                        case 'curr_month':
                            fromDate = new Date(today.getFullYear(), today.getMonth(), 1);
                            toDate = new Date(today.getFullYear(), today.getMonth() + 1, 0);
                            break;
                        case 'prev_month':
                            fromDate = new Date(today.getFullYear(), today.getMonth() - 1, 1);
                            toDate = new Date(today.getFullYear(), today.getMonth(), 0);
                            break;
                        case 'q1':
                            fromDate = new Date(today.getFullYear(), 0, 1);
                            toDate = new Date(today.getFullYear(), 3, 0);
                            break;
                        case 'q2':
                            fromDate = new Date(today.getFullYear(), 3, 1);
                            toDate = new Date(today.getFullYear(), 6, 0);
                            break;
                        case 'q3':
                            fromDate = new Date(today.getFullYear(), 6, 1);
                            toDate = new Date(today.getFullYear(), 9, 0);
                            break;
                        case 'q4':
                            fromDate = new Date(today.getFullYear(), 9, 1);
                            toDate = new Date(today.getFullYear(), 12, 0);
                            break;
                        case 'curr_year':
                            fromDate = new Date(today.getFullYear(), 0, 1);
                            toDate = new Date(today.getFullYear(), 12, 0); // Dec 31
                            break;
                        case 'prev_year':
                            fromDate = new Date(today.getFullYear() - 1, 0, 1);
                            toDate = new Date(today.getFullYear() - 1, 12, 0);
                            break;
                    }

                    fromDateInput.value = formatDate(fromDate);
                    toDateInput.value = formatDate(toDate);
                });
            });
        </script>

        <%- include('partials/footer') %>