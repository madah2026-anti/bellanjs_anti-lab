<%- include('partials/header', { title: 'التقارير' }) %>
    <%- include('partials/rightsidbar', { page: 'reports' }) %>

        <style>
            .window-content {
                padding: 10px;
            }

            .controls-row {
                display: flex;
                gap: 10px;
                margin-bottom: 10px;
            }

            .right-controls {
                flex: 1;
                display: flex;
                gap: 5px;
                align-items: stretch;
            }

            .left-controls {
                flex: 1;
                display: flex;
                gap: 5px;
                align-items: stretch;
            }

            .report-label {

                border: 1px solid #333;
                color: black;
                padding: 4px 15px;
                display: flex;
                align-items: center;
                font-weight: bold;
                flex: 1;
                justify-content: center;
            }

            .combo-box {
                padding: 4px;
                border: 1px solid #777;
                width: 250px;
                font-weight: bold;
                font-size: 16px;

            }

            .search-btn {

                border: 1px solid #333;
                color: black;
                padding: 4px 15px;
                font-weight: bold;
                cursor: pointer;
                width: 80px;
            }

            .search-input {
                flex: 1;
                padding: 4px;
                border: 1px solid #777;
            }

            .lists-container {
                display: flex;
                gap: 10px;
                margin-bottom: 5px;
            }

            .list-box {
                flex: 1;
                background-color: white;
                border: 1px solid #777;
                height: 350px;
                overflow-y: auto;
                padding: 10px;
            }

            .list-item {
                padding: 5px;
                cursor: pointer;
                text-align: right;
            }

            .list-item:hover {
                background-color: #e0f0ff;
            }

            .middle-blue-bar {

                border: 1px solid #4a75a9;
                height: 25px;
                margin-bottom: 10px;
                width: calc(50% - 5px);
                /* Same width as the left list box */
            }

            .bottom-controls {
                display: flex;
                gap: 20px;
                align-items: center;
                margin-bottom: 20px;
                margin-top: 15px;
            }

            .date-inputs {
                flex: 1;
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 10px;
            }

            .date-label {
                font-weight: bold;
                margin-left: 5px;
            }

            .date-input {
                padding: 4px;
                border: 1px solid #777;
                width: 200px;
            }

            .period-combo-container {
                flex: 1;
                display: flex;
                justify-content: flex-start;
            }

            .period-combo {
                padding: 4px;
                border: 1px solid #777;
                width: 250px;
            }

            .action-buttons {
                display: flex;
                justify-content: center;
                gap: 20px;
                margin-top: 10px;
                margin-bottom: 10px;
            }

            .action-btn {
                background: linear-gradient(to bottom, #a4c4e5, #6a96cd);
                border: 1px solid #fff;
                outline: 1px solid #4a75a9;
                color: white;
                font-weight: bold;
                padding: 5px 25px;
                border-radius: 4px;
                cursor: pointer;
                text-shadow: 1px 1px 1px rgba(0, 0, 0, 0.5);
            }

            .action-btn:hover {
                background: linear-gradient(to bottom, #b4d4f5, #7aa6dd);
            }
        </style>

        <main class="main-content">


            <div class="window-content">
                <!-- Top Controls -->
                <div class="controls-row">
                    <!-- Right Controls (Categories) -->
                    <div class="right-controls">
                        <div class="report-label">تقارير</div>
                        <select class="combo-box" id="category-select">
                            <option value="suppliers">الموردين</option>
                            <option value="customers">العملاء</option>
                            <option value="sales">المبيعات</option>
                            <option value="accounts">الحسابات</option>
                            <option value="inventory">المخزون</option>
                            <option value="purchases">خدمة العملاء </option>

                        </select>
                    </div>
                    <!-- Left Controls (Search) -->
                    <div class="left-controls">
                        <div class="report-label">بحث</div>
                        <input type="text" class="search-input" placeholder="">
                    </div>
                </div>

                <!-- Lists -->
                <div class="lists-container">
                    <!-- Right List (Report Names) -->
                    <div class="list-box" id="list-report-names">
                    </div>
                    <!-- Left List (Custom Data Search) and its count -->
                    <div style="flex: 1; display: flex; flex-direction: column;">
                        <div class="list-box" id="search-list"
                            style="height: 310px; max-height: 310px; overflow-y: auto; width: auto; flex: none;">
                            <!-- Custom data list will go here -->
                        </div>
                        <div class="middle-blue-bar" id="search-list-count"
                            style="width: 100%; margin-top: 5px; margin-bottom: 0;"></div>
                    </div>
                </div>

                <!-- Bottom Controls (Dates) -->
                <div class="bottom-controls">
                    <!-- Right part of bottom row (Dates) -->
                    <div class="date-inputs">
                        <span class="date-label">من تاريخ</span>
                        <input type="date" class="date-input" id="from-date">
                        <span class="date-label">الي تاريخ</span>
                        <input type="date" class="date-input" id="to-date">
                        <select class="period-combo" id="period-select">
                            <option value="none">بدون فترة</option>
                            <option value="prev_day">اليوم السابق</option>
                            <option value="curr_day">اليوم الحالي</option>
                            <option value="next_day">اليوم التالي</option>
                            <option value="curr_month">الشهر الحالي</option>
                            <option value="prev_month">الشهر السابق</option>
                            <option value="q1">الربع الاول</option>
                            <option value="q2">الربع الثاني</option>
                            <option value="q3">الربع الثالث</option>
                            <option value="q4">الربع الرابع</option>
                            <option value="curr_year">العام الحالي</option>
                            <option value="prev_year">العام السابق</option>

                        </select>
                    </div>


                </div>

                <!-- Action Buttons -->
                <div class="action-buttons">
                    <button class="action-btn">طباعة</button>
                    <button class="action-btn" onclick="window.history.back()">خروج</button>
                </div>
            </div>
        </main>

