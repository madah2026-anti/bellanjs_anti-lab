<%- include('../partials/header', { title: 'بيانات العملاء' }) %>
    <%- include('../partials/rightsidbar', { page: 'customers' }) %>

        <!-- Main Content -->
        <main class="main-content">
            <div class="content-header">
                <div
                    style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 15px;">
                    <div>
                        <h1 style="color: #3498db;">
                            <i class="fas fa-user-tie"></i> بيانات العملاء
                        </h1>
                        <p style="color: #666;">إدارة معلومات وعناوين العملاء</p>
                    </div>
                    <div style="display: flex; gap: 10px;">
                        <!-- Search Form -->
                        <form method="GET" action="/customers/data" style="display: flex;">
                            <input type="text" name="search" placeholder="بحث عن عميل..." value="<%= search %>"
                                style="padding: 10px; border: 1px solid #ddd; border-radius: 5px; width: 250px;">
                            <button type="submit" style="background: #3498db; color: white; border: none; 
                             padding: 10px 15px; border-radius: 5px; margin-right: 5px; cursor: pointer;">
                                <i class="fas fa-search"></i>
                            </button>
                        </form>

                        <!-- Add New Vendor Button -->
                        <a href="/customers/data/create" style="background: #2ecc71; color: white; border: none; padding: 10px 20px; 
                          border-radius: 8px; cursor: pointer; font-family: 'Cairo'; text-decoration: none;">
                            <i class="fas fa-plus"></i> إضافة عميل جديد
                        </a>
                    </div>
                </div>
            </div>

            <!-- Stats -->
            <div class="stats-grid">
                <div class="stat-card">
                    <i class="fas fa-users fa-2x" style="color: #3498db;"></i>
                    <div class="stat-number">
                        <%= totalcustomers %>
                    </div>
                    <div class="stat-label">إجمالي العملاء</div>
                </div>
                <div class="stat-card">
                    <i class="fas fa-file-invoice fa-2x" style="color: #2ecc71;"></i>
                    <div class="stat-number">0</div>
                    <div class="stat-label">فواتير هذا الشهر</div>
                </div>
                <div class="stat-card">
                    <i class="fas fa-money-bill-wave fa-2x" style="color: #e74c3c;"></i>
                    <div class="stat-number">0 </div>
                    <div class="stat-label">مدفوعات معلقة</div>
                </div>
                <div class="stat-card">
                    <i class="fas fa-star fa-2x" style="color: #f39c12;"></i>
                    <div class="stat-number">0</div>
                    <div class="stat-label">عملاء متميزين</div>
                </div>
            </div>

            <!-- Vendor List -->
            <div class="vendor-list-container">
                <div style="background: white; padding: 25px; border-radius: 15px; box-shadow: var(--light-shadow);">
                    <div
                        style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                        <h3 style="margin: 0; color: #3498db;">
                            <i class="fas fa-list"></i> قائمة العملاء (<%= customers.length %>)
                        </h3>

                        <% if(search) { %>
                            <div>
                                <span>نتائج البحث عن: "<%= search %>"</span>
                                <a href="/customers/data" style="color: #3498db; margin-right: 10px;">
                                    <i class="fas fa-times"></i> إلغاء البحث
                                </a>
                            </div>
                            <% } %>
                    </div>

                    <% if(customers.length> 0) { %>
                        <div style="overflow-x: auto;">
                            <table class="vendor-table">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>اسم العميل</th>
                                        <th>المحافظة</th>
                                        <th>المدينة</th>
                                        <th>العنوان</th>
                                        <th>الهاتف</th>
                                        <th>الإجراءات</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% customers.forEach((vendor, index)=> { %>
                                        <tr class="<%= index % 2 === 0 ? 'even' : 'odd' %>">
                                            <td>
                                                <%= index + 1 %>
                                            </td>
                                            <td style="font-weight: bold;">
                                                <%= vendor.cf_t1 %>
                                            </td>
                                            <td>
                                                <%= vendor.cf_t2 || 'غير محدد' %>
                                            </td>
                                            <td>
                                                <%= vendor.cf_t3 || 'غير محدد' %>
                                            </td>
                                            <td>
                                                <%= vendor.cf_t4 || 'غير محدد' %>
                                            </td>
                                            <td style="direction: ltr; text-align: right;">
                                                <%= vendor.cf_t5 || 'غير محدد' %>
                                            </td>
                                            <td>
                                                <a href="/customers/data/edit/<%= vendor.id %>" class="btn btn-view">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                <a href="/customers/data/edit/<%= vendor.id %>" class="btn btn-edit">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <!-- no need to delete in web -->
                                                <!-- <a href="/customers/data/delete/<%= vendor.id %>" class="btn btn-delete"
                                                    onclick="return confirm('هل أنت متأكد من حذف هذا العميل؟');">
                                                    <i class="fas fa-trash"></i>
                                                </a> -->
                                            </td>
                                        </tr>
                                        <% }); %>
                                </tbody>
                            </table>
                        </div>
                        <% } else { %>
                            <div style="text-align: center; padding: 40px; color: #666;">
                                <i class="fas fa-users fa-3x" style="color: #ddd; margin-bottom: 15px;"></i>
                                <h3 style="margin-bottom: 10px;">لا توجد بيانات</h3>
                                <p>لم يتم العثور على عملاء في قاعدة البيانات</p>
                                <% if(search) { %>
                                    <a href="/customers/data" style="display: inline-block; background: #3498db; color: white; padding: 10px 20px; 
                                  border-radius: 5px; text-decoration: none; margin-top: 15px;">
                                        عرض جميع العملاء
                                    </a>
                                    <% } else { %>
                                        <a href="/customers/data/create" style="display: inline-block; background: #2ecc71; color: white; padding: 10px 20px; 
                                  border-radius: 5px; text-decoration: none; margin-top: 15px;">
                                            <i class="fas fa-plus"></i> إضافة أول عميل
                                        </a>
                                        <% } %>
                            </div>
                            <% } %>

                                <!-- Pagination -->
                                <% if (totalPages> 1) { %>
                                    <div style="margin-top: 20px; display: flex; justify-content: center; gap: 5px;">
                                        <% if (currentPage> 1) { %>
                                            <a href="/customers/data?page=<%= currentPage - 1 %><%= search ? '&search=' + search : '' %>"
                                                style="padding: 8px 12px; border: 1px solid #ddd; border-radius: 5px; color: #333; text-decoration: none; background: white;">
                                                <i class="fas fa-chevron-right"></i> السابق
                                            </a>
                                            <% } %>
                                                <% for(let i=1; i <=totalPages; i++) { const linkStyle=currentPage===i
                                                    ? 'style="padding: 8px 12px; border: 1px solid #3498db; border-radius: 5px; color: white; text-decoration: none; background: #3498db;"'
                                                    : 'style="padding: 8px 12px; border: 1px solid #ddd; border-radius: 5px; color: #333; text-decoration: none; background: white;"'
                                                    ; %>
                                                    <a href="/customers/data?page=<%= i %><%= search ? '&search=' + search : '' %>"
                                                        <%- linkStyle %>>
                                                        <%= i %>
                                                    </a>
                                                    <% } %>

                                                        <% if (currentPage < totalPages) { %>
                                                            <a href="/customers/data?page=<%= currentPage + 1 %><%= search ? '&search=' + search : '' %>"
                                                                style="padding: 8px 12px; border: 1px solid #ddd; border-radius: 5px; color: #333; text-decoration: none; background: white;">
                                                                التالي <i class="fas fa-chevron-left"></i>
                                                            </a>
                                                            <% } %>
                                    </div>
                                    <div style="text-align: center; margin-top: 10px; color: #666; font-size: 0.9em;">
                                        صفحة <%= currentPage %> من <%= totalPages %>
                                    </div>
                                    <% } %>
                </div>
            </div>
        </main>
        <%- include('../partials/footer') %>