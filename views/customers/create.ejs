<%- include('../partials/header', { title: 'إضافة مورد جديد' }) %>
    <%- include('../partials/rightsidbar', { page: 'vendors' }) %>

        <!-- Vendor Sidebar -->
        <nav class="vendor-sidebar">
            <div class="vendor-header">
                <h2>العملاء</h2>
                <p>إدارة كافة عمليات العملاء</p>
            </div>

            <div class="vendor-nav">
                <a href="/customers/data" class="vendor-button active">
                    <i class="fas fa-user-tie"></i>
                    <span>بيانات العملاء</span>
                </a>

                <a href="#" class="vendor-button">
                    <i class="fas fa-file-invoice"></i>
                    <span>فاتورة مبيعات</span>
                </a>

                <a href="#" class="vendor-button">
                    <i class="fas fa-undo-alt"></i>
                    <span>مردودات</span>
                </a>

                <a href="#" class="vendor-button">
                    <i class="fas fa-file-contract"></i>
                    <span>إشعار دائن</span>
                </a>

                <a href="#" class="vendor-button">
                    <i class="fas fa-file-invoice-dollar"></i>
                    <span>إشعار مدين</span>
                </a>

                <a href="#" class="vendor-button">
                    <i class="fas fa-money-check-alt"></i>
                    <span>تحصيل</span>
                </a>
            </div>

            <div class="back-button">
                <a href="/" class="back-btn">
                    <i class="fas fa-arrow-right"></i>
                    <span>العودة للرئيسية</span>
                </a>
            </div>
        </nav>

        <!-- Main Content -->
        <main class="main-content">
            <div class="content-header">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <div>
                        <h1 style="color: #3498db;">
                            <i class="fas fa-user-plus"></i> إضافة عميل جديد
                        </h1>
                        <p style="color: #666;">إضافة عميل جديد إلى قاعدة البيانات</p>
                    </div>
                    <div>
                        <a href="javascript:history.back()"
                            style="background: #7f8c8d; color: white; border: none; padding: 10px 20px; border-radius: 8px; cursor: pointer; font-family: 'Cairo'; text-decoration: none;">
                            <i class="fas fa-arrow-right"></i> العودة للقائمة
                        </a>
                    </div>
                </div>
            </div>

            <div style="max-width: 800px; margin: 0 auto;">
                <div style="background: white; padding: 30px; border-radius: 15px; box-shadow: var(--light-shadow);">
                    <form method="POST" action="/customers/data/create">
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
                            <!-- Name Field -->
                            <div>
                                <label style="display: block; margin-bottom: 8px; color: #2c3e50; font-weight: bold;">
                                    <i class="fas fa-user-tie"></i> اسم العميل *
                                </label>
                                <input type="text" name="cf_t1" required
                                    style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-family: 'Cairo';"
                                    placeholder="أدخل اسم العميل">
                            </div>

                            <!-- Phone Field -->
                            <div>
                                <label style="display: block; margin-bottom: 8px; color: #2c3e50; font-weight: bold;">
                                    <i class="fas fa-phone"></i> رقم الهاتف
                                </label>
                                <input type="text" name="cf_t5"
                                    style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-family: 'Cairo'; direction: ltr; text-align: right;"
                                    placeholder="01XXXXXXXX">
                            </div>
                        </div>

                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
                            <!-- Governorate Field -->
                            <div>
                                <label style="display: block; margin-bottom: 8px; color: #2c3e50; font-weight: bold;">
                                    <i class="fas fa-map-marker-alt"></i> المحافظة
                                </label>
                                <select id="governorate" name="cf_t2" required
                                    style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-family: 'Cairo'; background: white;">
                                    <option value="">اختر المحافظة...</option>
                                    <% if (typeof governorates !=='undefined' ) { %>
                                        <% governorates.forEach(gov=> { %>
                                            <option value="<%= gov.gov_name %>">
                                                <%= gov.gov_name %>
                                            </option>
                                            <% }); %>
                                                <% } %>
                                </select>
                            </div>

                            <!-- City Field -->
                            <div>
                                <label style="display: block; margin-bottom: 8px; color: #2c3e50; font-weight: bold;">
                                    <i class="fas fa-city"></i> المدينة
                                </label>
                                <select id="city" name="cf_t3" required
                                    style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-family: 'Cairo'; background: white;">
                                    <option value="">اختر المدينة...</option>
                                </select>
                            </div>
                        </div>

                        <!-- Address Field -->
                        <div style="margin-bottom: 25px;">
                            <label style="display: block; margin-bottom: 8px; color: #2c3e50; font-weight: bold;">
                                <i class="fas fa-home"></i> العنوان التفصيلي
                            </label>
                            <textarea name="cf_t4" rows="3"
                                style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-family: 'Cairo'; resize: vertical;"
                                placeholder="العنوان التفصيلي"></textarea>
                        </div>

                        <!-- Submit Buttons -->
                        <div
                            style="display: flex; justify-content: space-between; align-items: center; border-top: 1px solid #eee; padding-top: 25px;">
                            <div>
                                <span style="color: #7f8c8d; font-size: 14px;">
                                    <i class="fas fa-info-circle"></i> الحقول المميزة بـ * إلزامية
                                </span>
                            </div>
                            <div style="display: flex; gap: 10px;">
                                <a href="/vendors/data"
                                    style="background: #95a5a6; color: white; border: none; padding: 12px 25px; border-radius: 8px; cursor: pointer; font-family: 'Cairo'; text-decoration: none;">
                                    إلغاء
                                </a>
                                <button type="submit"
                                    style="background: #2ecc71; color: white; border: none; padding: 12px 25px; border-radius: 8px; cursor: pointer; font-family: 'Cairo';">
                                    <i class="fas fa-save"></i> حفظ العميل
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </main>

        <script>
            document.addEventListener('DOMContentLoaded', function () {
                const govSelect = document.getElementById('governorate');
                const citySelect = document.getElementById('city');

                govSelect.addEventListener('change', function () {
                    const govName = this.value;
                    citySelect.innerHTML = '<option value="">جاري التحميل...</option>';
                    citySelect.disabled = true;

                    if (govName) {
                        fetch(`/vendors/cities?gov=${encodeURIComponent(govName)}`)
                            .then(response => response.json())
                            .then(cities => {
                                citySelect.innerHTML = '<option value="">اختر المدينة...</option>';
                                cities.forEach(city => {
                                    const option = document.createElement('option');
                                    option.value = city.city_name;
                                    option.textContent = city.city_name;
                                    citySelect.appendChild(option);
                                });
                                citySelect.disabled = false;
                            })
                            .catch(err => {
                                console.error('Error fetching cities:', err);
                                citySelect.innerHTML = '<option value="">خطأ في التحميل</option>';
                                citySelect.disabled = false;
                            });
                    } else {
                        citySelect.innerHTML = '<option value="">اختر المدينة...</option>';
                        citySelect.disabled = true; // Keep disabled if no governorate selected
                    }
                });
            });
        </script>

        <%- include('../partials/footer') %>