<%- include('../partials/header', { title: 'بيانات العملاء' }) %>
    <%- include('../partials/rightsidbar', { page: 'customers' }) %>


        <!-- Main Content -->
        <main class="main-content">
            <div class="content-header">
                <div
                    style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 15px;">
                    <div>
                        <h1 style="color: #3498db;">
                            <i class="fas fa-user-tie"></i>
                            <%= title %>
                        </h1>
                        <h3 style="color: #666;"> إجمالي عدد المستندات : <%= sales_invs_cnt %>
                        </h3>
                    </div>
                    <div style="display: flex; gap: 20px;">

                        <!-- Search Form , date filter , cat_name filter   -->
                        <form method="GET"
                            action="<%= typeof pagebackto !== 'undefined' ? pagebackto : '/customers/sales_list' %>"
                            style="display: flex;">
                            <input type="text" name="search" placeholder="بحث عن سند ..." value="<%= search %>"
                                style="padding: 10px; border: 1px solid #ddd; border-radius: 5px; width: 150px;">

                            <button type="submit" style="background: #3498db; color: white; border: none; 
                             padding: 10px 15px; border-radius: 5px; margin-right: 5px; cursor: pointer;">
                                <i class="fas fa-search"></i>
                            </button>
                        </form>

                        <!-- Add New Document Button based on title -->
                        <% let createLink="#" ; if (title==='فواتير المبيعات' ) { createLink="/customers/sales_create" ;
                            } else if (title==='حوافز العملاء' ) { createLink="/customers/bounce_create" ; } else if
                            (title==='هدايا العملاء' ) { createLink="/customers/gifts_create" ; } %>
                            <a href="<%= createLink %>" style="background: #2ecc71; color: white; border: none; padding: 10px 20px; 
                          border-radius: 8px; cursor: pointer; font-family: 'Cairo'; text-decoration: none;">
                                <i class="fas fa-file-invoice"></i> إضافة مستند جديدة
                            </a>
                    </div>
                </div>
            </div>

            <!-- 
                <!-- Stats 
                <div class="stats-grid">
                    <div class="stat-card">
                        <i class="fas fa-users fa-2x" style="color: #3498db;"></i>
                        <div class="stat-number">
                            <%= sales_invs_cnt %>
                        </div>
                        <div class="stat-label">إجمالي الفواتير</div>
                    </div>
                    <div class="stat-card">
                        <i class="fas fa-file-invoice fa-2x" style="color: #2ecc71;"></i>
                        <div class="stat-number">0</div>
                        <div class="stat-label">فواتير هذا الشهر</div>
                    </div>
                    <div class="stat-card">
                        <i class="fas fa-money-bill-wave fa-2x" style="color: #e74c3c;"></i>
                        <div class="stat-number">0 ر.س</div>
                        <div class="stat-label">مدفوعات معلقة</div>
                    </div>
                    <div class="stat-card">
                        <i class="fas fa-star fa-2x" style="color: #f39c12;"></i>
                        <div class="stat-number">0</div>
                        <div class="stat-label">عملاء متميزين</div>
                    </div>
                </div>
                -->
            <!-- Sales Invoices List -->
            <div class="vendor-list-container">
                <div style="background: white; padding: 25px; border-radius: 15px; box-shadow: var(--light-shadow);">
                    <div <% if(search) { %>
                        <div>
                            <span>نتائج البحث عن: "<%= search %>"</span>
                            <a href="/customers/sales_list" style="color: #3498db; margin-right: 10px;">
                                <i class="fas fa-times"></i> إلغاء البحث
                            </a>
                        </div>
                        <% } %>
                    </div>

                    <% if(sales_invs.length> 0) { %>
                        <div style="overflow-x: auto;">
                            <table class="vendor-table">
                                <thead>
                                    <tr>
                                        <th style="width:5%;">#</th>
                                        <th style="width:10%;">تصنيف السند</th>
                                        <th style="width:10%;">رقم السند</th>
                                        <th style="width:10%;">تاريخ السند</th>
                                        <th style="width:30%;">اسم العميل</th>
                                        <th style="width:10%;">القيمة </th>
                                        <th style="width:20%;"> البيان </th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% sales_invs.forEach((vendor, index)=> { %>
                                        <tr class=" <%=index % 2===0 ? 'even' : 'odd' %>">
                                            <td>
                                                <%= index + 1 %>
                                            </td>
                                            <td>
                                                <%=vendor.cash_cat_name || 'غير محدد' %>
                                            </td>
                                            <td>
                                                <a href="/customers/doc_show/<%=vendor.cash_ser %>">
                                                    <%=vendor.cash_ser || 'غير محدد' %>
                                                </a>
                                            </td>
                                            <td>
                                                <%= vendor.cash_date ? new
                                                    Date(vendor.cash_date).toISOString().split('T')[0] : 'غير محدد' %>
                                            </td>
                                            <td>
                                                <%= vendor.cash_cv_name || 'غير محدد' %>
                                            </td>
                                            <td>
                                                <%= vendor.cash_amount || 'غير محدد' %>
                                            </td>
                                            <td style="direction: ltr; text-align: right;">
                                                <%= vendor.cash_notes || 'غير محدد' %>
                                            </td>
                                        </tr>
                                        <% }); %>
                                </tbody>
                            </table>
                        </div>
                        <% } else { %>
                            <div style="text-align: center; padding: 40px; color: #666;">
                                <i class="fas fa-users fa-3x" style="color: #ddd; margin-bottom: 15px;"></i>
                                <h3 style="margin-bottom: 10px;">لا توجد بيانات</h3>
                                <p>لم يتم العثور على هذا الرقم في قاعدة البيانات</p>
                                <% if(search) { %>
                                    <a href="/customers/sales_list" style="display: inline-block; background: #3498db; color: white; padding: 10px 20px; 
                                  border-radius: 5px; text-decoration: none; margin-top: 15px;">
                                        عرض جميع الفواتير
                                    </a>
                                    <% } else { %>
                                        <a href="/customers/data/create" style="display: inline-block; background: #2ecc71; color: white; padding: 10px 20px; 
                                  border-radius: 5px; text-decoration: none; margin-top: 15px;">
                                            <i class="fas fa-plus"></i> إضافة أول عميل
                                        </a>
                                        <% } %>
                            </div>
                            <% } %>

                </div>
            </div>
        </main>
        <%- include('../partials/footer') %>